# Copy to .env for local runs; in Railway set these as service Variables instead.
# Supabase SESSION POOLER string (Dashboard -> Connect -> Session pooler). IPv4-friendly.
DATABASE_URL=postgresql://postgres.sawwgimqhmjoihflgzjw:YOURPASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Password your client types to enter the app.
APP_PASSWORD=choose-a-strong-password
# Random string used to sign the login cookie (e.g. `openssl rand -hex 32`).
SECRET_KEY=replace-with-a-long-random-string
